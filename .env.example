# Supabase — público (seguro para o browser)
# Obter em: app.supabase.com/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# URL pública do site — usada no emailRedirectTo do Magic Link
# Desenvolvimento local: http://localhost:3003
# Produção: https://neurolearn.tech
NEXT_PUBLIC_SITE_URL=https://neurolearn.tech

# Supabase — apenas server-side (NUNCA em NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# IA — apenas server-side (NUNCA em NEXT_PUBLIC_*)
# Provider: OpenAI (Fase 5)
OPENAI_API_KEY=<openai-api-key>
